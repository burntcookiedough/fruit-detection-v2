# Auto-detect text files and normalise line endings
* text=auto

# Source code — enforce LF
*.py text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.txt text eol=lf
*.sh text eol=lf
*.json text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.csv text eol=lf

# Windows scripts — enforce CRLF
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files — do not diff
*.pt binary
*.pth binary
*.onnx binary
*.npy binary
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
