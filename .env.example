# Copy this file to .env and edit values for your machine.
# Paths can be absolute or relative to the repository root.

# Runtime mode used by run.sh / run.ps1 / run.bat:
# image, webcam, train, verify, export
FRUIT_RUN_MODE=image

# Dataset layout:
# dataset/
#   train/images, train/labels
#   valid/images, valid/labels
#   test/images, test/labels
FRUIT_DATA_DIR=dataset
# FRUIT_TRAIN_IMG_DIR=dataset/train/images
# FRUIT_TRAIN_LBL_DIR=dataset/train/labels
# FRUIT_VAL_IMG_DIR=dataset/valid/images
# FRUIT_VAL_LBL_DIR=dataset/valid/labels
# FRUIT_TEST_IMG_DIR=dataset/test/images
# FRUIT_TEST_LBL_DIR=dataset/test/labels

# Model artifacts
FRUIT_RUNS_DIR=runs/fruit_v2
FRUIT_WEIGHTS_DIR=runs/fruit_v2/weights
FRUIT_WEIGHTS=runs/fruit_v2/weights/best_map50.pt
FRUIT_INPUT_IMAGE=image.png
FRUIT_OUTPUT_IMAGE=output_inference.png
FRUIT_ONNX_OUTPUT=fruit_detector_v2.onnx

# Inference
FRUIT_CONF_THRESH=0.05
FRUIT_NMS_IOU=0.45
FRUIT_PRE_NMS_TOPK=1000
FRUIT_MAX_DETECTIONS=100
FRUIT_CAMERA_ID=0
# FRUIT_LABEL_FONT=/path/to/font.ttf

# Model architecture
FRUIT_BACKBONE_NAME=convnext_femto.d1_in1k
FRUIT_PRETRAINED=true
FRUIT_NECK_CHANNELS=96
FRUIT_REG_MAX=8
FRUIT_STRIDES=8,16,32
FRUIT_IMG_SIZE=352
FRUIT_NUM_CLASSES=8
FRUIT_CLASS_NAMES=apple,banana,orange,mango,pineapple,watermelon,grapes,pomegranate

# Training
FRUIT_BATCH_SIZE=48
FRUIT_NUM_EPOCHS=40
FRUIT_LR_BACKBONE=0.001
FRUIT_LR_HEAD=0.005
FRUIT_WEIGHT_DECAY=0.005
FRUIT_GRAD_CLIP=1.0
FRUIT_FREEZE_BACKBONE_EPOCHS=2
FRUIT_CLS_WEIGHT=1.0
FRUIT_BOX_WEIGHT=2.5
FRUIT_DFL_WEIGHT=0.5
FRUIT_TAL_TOPK=10
FRUIT_PATIENCE=20
FRUIT_VAL_EVERY=5

# Augmentation
FRUIT_MOSAIC_PROB=0.5
FRUIT_MIXUP_PROB=0.15
FRUIT_COPY_PASTE_PROB=0.15
FRUIT_MOSAIC_OFF_EPOCHS=10

# DataLoader
FRUIT_NUM_WORKERS=8
FRUIT_PREFETCH_FACTOR=4
FRUIT_PERSISTENT_WORKERS=true
