# ============================================================
# Docker build context exclusions
# Keep the build context small and avoid leaking secrets/data
# ============================================================

# Version control
.git/
.gitattributes
.gitignore

# Python artifacts
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo

# Tool caches
.mypy_cache/
.ruff_cache/
.pytest_cache/
.hypothesis/
htmlcov/
.coverage
.coverage.*

# Project data (large, mounted at runtime)
dataset/
datasets/
cache/
output/
runs/

# Model weights (large binaries)
*.pt
*.pth
*.onnx
*.weights

# Documentation & non-build files
docs/
*.md
LICENSE
CONTRIBUTING.md
.pre-commit-config.yaml
.env
.env.*
!.env.example

# Agents
.agents/

# OS artifacts
Thumbs.db
.DS_Store
